---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, heroImage, heroImages, postId } = Astro.props;
const heroList = (Array.isArray(heroImages) ? heroImages : heroImage ? [heroImage] : []).filter(Boolean);
const allPosts = (await getCollection('blog'))
  .filter(({ id }) => /^\d+-avventura$/.test(id))
  .sort((a, b) => parseInt(a.id) - parseInt(b.id));
const currentIndex = allPosts.findIndex((p) => p.id === postId);
const prev = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
---

<html lang="it">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.article-page {
				padding: 2.2rem 0 4rem;
			}

			.article-shell {
				padding: 1.75rem;
				border: 1px solid rgba(var(--border), 0.45);
				border-radius: var(--radius);
				background:
					linear-gradient(180deg, rgba(var(--storm-ivory-rgb), 0.92), rgba(var(--storm-mist-rgb), 0.24));
				box-shadow: var(--box-shadow);
			}

			.hero-image {
				width: 100%;
				margin-bottom: 1.5rem;
			}

			.hero-image img {
				display: block;
				width: 100%;
				height: 100%;
				margin: 0 auto;
				object-fit: cover;
				border-radius: calc(var(--radius) - 6px);
				box-shadow: var(--box-shadow);
			}

			.hero-grid {
				display: grid;
				gap: 0.9rem;
			}

			.hero-grid.two {
				grid-template-columns: 1fr 1fr;
			}

			.prose {
				color: rgb(var(--gray-dark));
			}

			.title {
				padding: 0.5rem 0 0;
				margin-bottom: 2rem;
				text-align: center;
			}

			.title h1 {
				margin-bottom: 0.75rem;
			}

			.post-nav {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.85rem;
				margin-top: 3rem;
			}

			.post-nav a,
			.post-nav span {
				min-height: 4.7rem;
				padding: 1rem 1.1rem;
				border-radius: var(--radius-sm);
				border: 1px solid rgba(var(--border), 0.42);
				background: rgba(var(--storm-ivory-rgb), 0.72);
				text-decoration: none;
				color: rgb(var(--black));
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
			}

			.post-nav span {
				opacity: 0.4;
			}

			.post-nav a:hover {
				color: var(--accent-dark);
				transform: translateY(-2px);
			}

			.post-nav .index {
				font-weight: 700;
			}

			@media (max-width: 720px) {
				.article-page {
					padding-top: 1.5rem;
				}

				.article-shell {
					padding: 1rem;
				}

				.hero-grid.two {
					grid-template-columns: 1fr;
				}

				.post-nav {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main class="container article-page">
			<article class="article-shell">
				{heroList.length > 0 && (
					<div class="hero-image">
						<div class={`hero-grid ${heroList.length >= 2 ? 'two' : ''}`}>
							{heroList.map((img) => (
								<Image width={1020} height={510} src={img} alt="" />
							))}
						</div>
					</div>
				)}
				<div class="prose">
					<div class="title">
						<p class="eyebrow">Capitolo di campagna</p>
						<h1>{title}</h1>
					</div>
					<slot />
					<nav class="post-nav">
						{prev ? <a class="prev" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/') }blog/${prev.id}/`}>← {prev.data.title}</a> : <span>Avventura precedente</span>}
						<a class="index" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/') }blog/`}>Indice</a>
						{next ? <a class="next" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/') }blog/${next.id}/`}>{next.data.title} →</a> : <span>Avventura successiva</span>}
					</nav>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
