---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection, render } from 'astro:content';
import RisolutoriOg from '../assets/blog-placeholder-about.jpg';
import fs from 'node:fs';
import path from 'node:path';

const posts = (await getCollection('blog'))
	.filter(({ id }) => /^\d+-avventura$/.test(id))
	.sort((a, b) => parseInt(a.id) - parseInt(b.id));

const sessionsBase = new URL('../../public/images/sessions/', import.meta.url).pathname;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const totalPosts = posts.length;

function findThumb(num) {
	const dir = path.join(sessionsBase, String(num).padStart(3, '0'));
	if (!fs.existsSync(dir)) return '';
	const file = (fs.readdirSync(dir)
		.filter((f) => /\.(png|jpe?g|webp)$/i.test(f))
		.sort()[0]) || '';
	return file ? `${base}images/sessions/${String(num).padStart(3, '0')}/${encodeURI(file)}` : '';
}

const previews = await Promise.all(
	posts.map(async (p) => {
		const { headings } = await render(p);
        const sections = headings
            .filter((h) => (h.depth === 2 || h.depth === 3) && h.text.trim() !== p.data.title.trim())
            .map((h) => h.text)
			.slice(0, 3);
		const dateFromDesc = (p.data.description?.match(/\b\d{2}\/\d{2}\/\d{4}\b/) || [])[0];
		const dateLabel = dateFromDesc || new Date(p.data.pubDate).toLocaleDateString('it-IT');
		return {
			id: p.id,
			title: p.data.title,
			num: parseInt(p.id),
			dateLabel,
			sections,
			thumb: findThumb(parseInt(p.id)),
		};
	})
);
---

<!doctype html>
<html lang="it">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={RisolutoriOg} />
	</head>
	<body>
		<Header />
		<main class="container home-page">
			<section class="hero">
				<div class="hero-body">
					<p class="eyebrow">Diario di campagna • D&amp;D 5e</p>
					<h1>Storm King's Thunder</h1>
					<p class="hero-lead">
						Un archivio narrativo semplice da consultare, costruito per seguire l’intera campagna con immagini, capitoli e rimandi rapidi tra le sessioni.
					</p>
					<p class="hero-date"><strong>30 di Ches 1486</strong></p>
					<p class="hero-copy">
						Sono ormai due mesi che gli attacchi dei giganti si fanno sempre più pressanti in quella che viene comunemente definita la frontiera selvaggia. Giganti di diverso tipo si stanno muovendo, avvicinandosi pericolosamente alle zone più civilizzate: le mura di queste città non sarebbero preparate ad attacchi di tale portata. Le varie fazioni si stanno organizzando con l’obiettivo di capire il motivo di tali movimentazioni, e, se possibile, trovare un modo di debellare tale minaccia. Esploratori e avventurieri sono quindi stati inviati ad indagare; i giganti potrebbero mettere a serio rischio l’ordine e la stabilità del nord.
					</p>
					<p class="hero-copy">
						Huldur Winedale, esploratore dei nani di Citadel Adbar, Krjiv Linxakasèndalor di Tymanther, iniziato e Osservatore per conto degli Arpisti, Aerendir Frostwood, un eladrin vincolato da un desiderio magico a servire l’Enclave di Smeraldo, e Kyle Greenwich, Paladino degli Antichi, incaricato di aiutare e proteggere l’eladrin, si incontrano al di fuori di Nightstone, cittadina a est della strada che collega Waterdeep e Daggerford.
					</p>
					<div class="hero-actions">
						<a class="button" href={`${base}blog/1-avventura/`}>Inizia dal primo capitolo</a>
						<a class="button secondary" href={`${base}blog/`}>Sfoglia l’indice completo</a>
					</div>
					<ul class="hero-stats" aria-label="Panoramica rapida della campagna">
						<li><strong>{totalPosts}</strong><span>avventure</span></li>
						<li><strong>4</strong><span>protagonisti iniziali</span></li>
						<li><strong>1</strong><span>diario illustrato</span></li>
					</ul>
				</div>
				<div class="hero-media">
					<img class="hero-image" src={`${base}images/home/1_Nightstone.png`} alt="Nightstone" />
					<div class="hero-panel">
						<p class="eyebrow">Punto di partenza</p>
						<h2>Nightstone</h2>
						<p>Il viaggio inizia ai margini della frontiera, con un villaggio colpito dai giganti e quattro personaggi costretti a muoversi insieme.</p>
						<a class="hero-panel-link" href={`${base}about/`}>Chi sono i Risolutori</a>
					</div>
				</div>
			</section>

			<section class="home-section">
				<div class="section-copy">
					<p class="eyebrow">Archivio sessioni</p>
					<h2>Capitoli rapidi da consultare</h2>
					<p>Ogni card riassume l’avventura e porta ai momenti principali. Su desktop si scorre a schede, su mobile resta leggibile e usabile con il solo touch.</p>
				</div>
			</section>

			<div class="carousel" role="region" aria-label="Avventure (scorri orizzontalmente)" data-carousel>
				<button class="nav prev" type="button" aria-label="Precedenti" data-direction="-1">←</button>
				<div class="carousel-track" tabindex="0">
					{previews.map((post) => (
						<a class="card" href={`${base}blog/${post.id}/`} aria-label={`Avventura ${post.num}: ${post.title}`}>
							{post.thumb && <img class="thumb" src={post.thumb} alt="" loading="lazy" />}
							<span class="num">{post.num}° Avventura</span>
							<span class="title">{post.title}</span>
							<strong class="date">{post.dateLabel}</strong>
							{post.sections.length > 0 && (
								<ul class="sections">
									{post.sections.map((s) => (
										<li>{s}</li>
									))}
								</ul>
							)}
						</a>
					))}
				</div>
				<button class="nav next" type="button" aria-label="Successive" data-direction="1">→</button>
			</div>
		</main>
		<style>
			.home-page {
				padding: 2.2rem 0 4rem;
			}

			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
				align-items: center;
				gap: 2rem;
				padding: 2rem;
				border: 1px solid rgba(var(--border), 0.45);
				border-radius: var(--radius);
				background:
					linear-gradient(135deg, rgba(var(--storm-ivory-rgb), 0.82), rgba(var(--storm-mist-rgb), 0.26)),
					radial-gradient(circle at top right, rgba(var(--storm-sea-rgb), 0.2), transparent 34%);
				box-shadow: var(--box-shadow);
			}

			.hero-body {
				min-width: 0;
			}

			.hero-body h1 {
				margin-bottom: 0.75rem;
			}

			.hero-lead {
				font-size: clamp(1.1rem, 1rem + 0.4vw, 1.35rem);
				line-height: 1.7;
				color: rgb(var(--black));
				max-width: 32rem;
			}

			.hero-date {
				margin-bottom: 0.75rem;
				color: var(--accent-dark);
			}

			.hero-copy {
				max-width: 42rem;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.85rem;
				margin-top: 1.75rem;
			}

			.hero-stats {
				list-style: none;
				margin: 1.5rem 0 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.85rem;
			}

			.hero-stats li {
				padding: 1rem;
				border: 1px solid rgba(var(--border), 0.35);
				border-radius: var(--radius-sm);
				background: rgba(var(--storm-ivory-rgb), 0.6);
			}

			.hero-stats strong,
			.hero-stats span {
				display: block;
			}

			.hero-stats strong {
				font-size: 1.5rem;
				color: rgb(var(--black));
			}

			.hero-stats span {
				font-size: 0.92rem;
				color: rgb(var(--gray));
			}

			.hero-media {
				display: grid;
				gap: 1rem;
			}

			.hero-image {
				width: 100%;
				display: block;
				aspect-ratio: 5 / 4;
				object-fit: cover;
				border-radius: calc(var(--radius) - 4px);
				box-shadow: var(--box-shadow);
			}

			.hero-panel {
				padding: 1.25rem;
				border: 1px solid rgba(var(--border), 0.4);
				border-radius: var(--radius-sm);
				background: rgba(var(--storm-ivory-rgb), 0.92);
			}

			.hero-panel h2 {
				margin-bottom: 0.5rem;
			}

			.hero-panel p {
				margin-bottom: 0.8rem;
			}

			.hero-panel-link {
				font-weight: 700;
				text-decoration: none;
			}

			.home-section {
				padding: 2.5rem 0 1rem;
			}

			.section-copy {
				max-width: 40rem;
			}

			.carousel {
				position: relative;
			}

			.carousel .nav {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 3rem;
				height: 3rem;
				border: 1px solid rgba(var(--border), 0.55);
				border-radius: 50%;
				background: rgba(var(--storm-ivory-rgb), 0.92);
				color: rgb(var(--black));
				cursor: pointer;
				box-shadow: var(--box-shadow);
				z-index: 2;
			}

			.carousel .nav.prev {
				left: 0.3rem;
			}

			.carousel .nav.next {
				right: 0.3rem;
			}

			.carousel-track {
				display: flex;
				gap: 1rem;
				padding: 0.5rem 3.8rem 1rem;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;
			}

			.carousel-track::-webkit-scrollbar {
				display: none;
			}

			.card {
				display: flex;
				flex-direction: column;
				gap: 0.65rem;
				min-width: min(22rem, 78vw);
				padding: 1rem;
				border: 1px solid rgba(var(--border), 0.45);
				border-radius: calc(var(--radius) - 6px);
				text-decoration: none;
				color: inherit;
				scroll-snap-align: start;
				background:
					linear-gradient(180deg, rgba(var(--storm-ivory-rgb), 0.92), rgba(var(--storm-mist-rgb), 0.24));
				box-shadow: var(--box-shadow);
			}

			.card:hover {
				transform: translateY(-4px);
			}

			.card .thumb {
				width: 100%;
				height: 12rem;
				object-fit: cover;
				border-radius: var(--radius-sm);
			}

			.card .num {
				font-weight: 700;
				font-size: 0.78rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--accent-dark);
			}

			.card .title {
				font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
				font-size: 1.45rem;
				line-height: 1.1;
				color: rgb(var(--black));
			}

			.card .date {
				color: rgb(var(--gray-dark));
			}

			.card .sections {
				list-style: none;
				margin: 0.25rem 0 0;
				padding: 0;
				color: rgb(var(--gray));
			}

			.card .sections li + li {
				margin-top: 0.28rem;
			}

			@media (max-width: 720px) {
				.home-page {
					padding-top: 1.5rem;
				}

				.hero {
					grid-template-columns: 1fr;
					padding: 1.2rem;
					gap: 1.3rem;
				}

				.hero-stats {
					grid-template-columns: 1fr;
				}

				.hero-panel {
					padding: 1rem;
				}

				.carousel .nav {
					display: none;
				}

				.carousel-track {
					padding-inline: 0;
				}

				.card {
					min-width: 86vw;
				}
			}
		</style>
		<script is:inline>
			document.querySelectorAll('[data-carousel]').forEach((carousel) => {
				const track = carousel.querySelector('.carousel-track');
				if (!track) return;

				carousel.querySelectorAll('[data-direction]').forEach((button) => {
					button.addEventListener('click', () => {
						const direction = Number(button.getAttribute('data-direction')) || 1;
						const amount = Math.max(track.clientWidth * 0.82, 280) * direction;

						try {
							track.scrollBy({ left: amount, behavior: 'smooth' });
						} catch {
							track.scrollLeft += amount;
						}
					});
				});
			});
		</script>
		<Footer />
	</body>
</html>
