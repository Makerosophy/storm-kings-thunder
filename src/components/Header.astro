---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const links = [
	{ href: base, label: 'Intro' },
	{ href: `${base}blog/`, label: 'Avventure' },
	{ href: `${base}about/`, label: 'Risolutori' },
];
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="brand" href={base} aria-label={`${SITE_TITLE}, torna alla home`}>
			<span class="brand-mark">SKT</span>
			<span class="brand-copy">
				<strong>{SITE_TITLE}</strong>
				<small>Diario illustrato di campagna</small>
			</span>
		</a>
		<nav class="site-nav site-nav--desktop" aria-label="Navigazione principale">
			{links.map((link) => (
				<HeaderLink href={link.href}>{link.label}</HeaderLink>
			))}
		</nav>
		<details class="site-menu">
			<summary class="site-menu__toggle">Menu</summary>
			<nav class="site-nav site-nav--mobile" aria-label="Navigazione mobile">
				{links.map((link) => (
					<HeaderLink href={link.href}>{link.label}</HeaderLink>
				))}
			</nav>
		</details>
	</div>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 1rem 0 0;
	}

	.site-header__inner {
		width: min(100% - 2rem, var(--page-width));
		margin: 0 auto;
		padding: 0.9rem 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem 1.5rem;
		position: relative;
		border: 1px solid rgba(var(--border), 0.45);
		border-radius: 999px;
		background: rgba(var(--storm-ivory-rgb), 0.86);
		box-shadow: var(--box-shadow);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
	}

	.site-menu {
		display: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		color: rgb(var(--black));
		text-decoration: none;
		margin: 0;
	}

	.brand-mark {
		display: inline-grid;
		place-items: center;
		width: 2.85rem;
		height: 2.85rem;
		border-radius: 50%;
		background:
			linear-gradient(180deg, rgba(var(--storm-mist-rgb), 1), rgba(var(--storm-night-rgb), 1));
		color: rgb(var(--storm-ivory-rgb));
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		box-shadow: 0 14px 24px rgba(var(--storm-night-rgb), 0.22);
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
		gap: 0.12rem;
	}

	.brand-copy strong {
		font-size: 0.98rem;
		line-height: 1.1;
	}

	.brand-copy small {
		font-size: 0.76rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	.site-nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.45rem;
	}

	.site-nav :global(a) {
		padding: 0.8rem 1rem;
		border-radius: 999px;
		color: rgb(var(--black));
		text-decoration: none;
		font-weight: 600;
	}

	.site-nav :global(a:hover) {
		background: rgba(var(--storm-ivory-rgb), 0.8);
	}

	.site-nav :global(a.active) {
		background: rgba(var(--storm-mist-rgb), 0.14);
		color: var(--accent-dark);
		box-shadow: inset 0 0 0 1px rgba(var(--storm-mist-rgb), 0.16);
	}

	.site-menu__toggle {
		list-style: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 5.4rem;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(var(--border), 0.42);
		background: rgba(var(--storm-ivory-rgb), 0.94);
		color: rgb(var(--black));
		font: inherit;
		font-weight: 700;
		cursor: pointer;
		user-select: none;
	}

	.site-menu__toggle::-webkit-details-marker {
		display: none;
	}

	.site-menu[open] .site-menu__toggle {
		background: rgba(var(--storm-mist-rgb), 0.14);
		color: var(--accent-dark);
	}

	@media (max-width: 720px) {
		.site-header {
			padding-top: 0.75rem;
		}

		.site-header__inner {
			width: min(100% - 1rem, var(--page-width));
			padding: 0.75rem 0.85rem;
			border-radius: 999px;
			gap: 0.85rem;
		}

		.brand {
			min-width: 0;
			flex: 1 1 auto;
		}

		.brand-mark {
			width: 2.45rem;
			height: 2.45rem;
			font-size: 0.95rem;
		}

		.brand-copy {
			min-width: 0;
		}

		.brand-copy strong {
			font-size: 0.9rem;
		}

		.brand-copy small {
			font-size: 0.68rem;
		}

		.site-nav--desktop {
			display: none;
		}

		.site-menu {
			display: block;
			position: relative;
		}

		.site-nav--mobile {
			position: absolute;
			top: calc(100% + 0.7rem);
			right: 0;
			width: min(18rem, calc(100vw - 1rem));
			padding: 0.55rem;
			display: grid;
			gap: 0.3rem;
			border: 1px solid rgba(var(--border), 0.45);
			border-radius: 24px;
			background: rgba(var(--storm-ivory-rgb), 0.98);
			box-shadow: 0 16px 34px rgba(var(--storm-night-rgb), 0.18);
		}

		.site-nav--mobile :global(a) {
			padding: 0.85rem 0.95rem;
			text-align: left;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.site-header__inner {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
			background: rgba(var(--storm-ivory-rgb), 0.96);
		}
	}
</style>
