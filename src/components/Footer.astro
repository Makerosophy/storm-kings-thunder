---
const today = new Date();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<p class="site-footer__title">Storm King's Thunder</p>
		<p class="site-footer__copy">
			&copy; {today.getFullYear()} Una storia di giganti, viaggi e reliquie perdute.
		</p>
		<nav class="site-footer__links" aria-label="Link rapidi">
			<a href={base}>Intro</a>
			<a href={`${base}blog/`}>Indice avventure</a>
			<a href={`${base}about/`}>Risolutori</a>
		</nav>
	</div>
</footer>
<style>
	.site-footer {
		padding: 2.5rem 0 3rem;
	}

	.site-footer__inner {
		width: min(100% - 2rem, var(--page-width));
		margin: 0 auto;
		padding: 1.5rem 1.75rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border-top: 1px solid rgba(var(--border), 0.55);
		color: rgb(var(--gray));
		text-align: center;
	}

	.site-footer__title,
	.site-footer__copy {
		margin: 0;
	}

	.site-footer__title {
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
		font-size: 1.1rem;
		color: rgb(var(--black));
	}

	.site-footer__links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 1rem;
		margin-top: 0.45rem;
	}

	.site-footer__links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}

	.site-footer__links a:hover {
		color: var(--accent);
	}

	@media (max-width: 720px) {
		.site-footer {
			padding-top: 2rem;
		}

		.site-footer__inner {
			width: min(100% - 1rem, var(--page-width));
			padding-inline: 1rem;
		}
	}
</style>
